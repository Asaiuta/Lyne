{
  "name": "audio-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tauri": "npm run build:sidecar && vite",
    "build": "npm run build:web",
    "build:web": "vite build",
    "build:measure": "npm run build:web && npm run perf:bundle",
    "build:sidecar": "cargo build --release --manifest-path ../../Cargo.toml --bin audio_server",
    "build:bundle": "npm run build:web && npm run build:sidecar",
    "preview": "vite preview",
    "perf:bundle": "node ./scripts/report-bundle-size.mjs",
    "perf:electron-webaudio": "electron ./scripts/electron-webaudio-baseline.cjs",
    "perf:electron-realtime-playback": "node ./scripts/electron-realtime-playback-baseline.cjs",
    "perf:electron-real-file-playback": "node ./scripts/electron-real-file-playback-baseline.cjs",
    "perf:lyne-control-probe": "node ./scripts/lyne-active-playback-control-probe.cjs",
    "perf:lyne-playback-latency": "node ./scripts/lyne-playback-latency-benchmark.cjs",
    "perf:lyne-playback-stability": "node ./scripts/lyne-playback-stability-benchmark.cjs",
    "perf:library-scan-evidence": "node ./scripts/lyne-library-scan-evidence.cjs",
    "perf:real-library-benchmark": "node ./scripts/lyne-real-library-benchmark.cjs",
    "perf:splayer-library-benchmark": "node ./scripts/splayer-library-benchmark.cjs",
    "perf:routes": "node ./scripts/measure-route-loads.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node ./scripts/run-focused-tests.mjs",
    "tauri": "powershell -ExecutionPolicy Bypass -File ./scripts/tauri-wrapper.ps1"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@material/material-color-utilities": "^0.4.0",
    "@tauri-apps/api": "^2.0.0",
    "qrcode": "^1.5.4",
    "solid-js": "^1.9.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@unocss/transformer-variant-group": "^66.6.8",
    "electron": "^39.4.0",
    "typescript": "^5.6.3",
    "unocss": "^66.6.8",
    "vite": "^5.4.8",
    "vite-plugin-solid": "^2.11.0"
  }
}
