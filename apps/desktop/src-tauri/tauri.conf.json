{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lyne",
  "version": "0.1.0",
  "identifier": "com.audio.desktop",
  "build": {
    "beforeBuildCommand": "npm run build:bundle",
    "beforeDevCommand": "npm run dev:tauri",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lyne",
        "width": 1220,
        "height": 780,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "../../../target/release/audio_server.exe",
      "../../../target/release/libsoxr.dll"
    ]
  }
}
